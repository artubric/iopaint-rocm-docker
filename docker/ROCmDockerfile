ARG PLATFORM=linux/amd64
FROM --platform=${PLATFORM} rocm/pytorch:rocm7.1.1_ubuntu22.04_py3.11_pytorch_release_2.10.0

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV HSA_OVERRIDE_GFX_VERSION=10.3.0
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    libsm6 libxext6 ffmpeg libfontconfig1 libxrender1 libgl1-mesa-glx \
    libglib2.0-0 \
    curl python3-pip git \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Upgrade pip only
RUN pip3 install --no-cache-dir --upgrade pip

WORKDIR /app

# Copy the entire project
COPY . .

# Install IOPaint and its dependencies 
# We filter out torch/torchvision to keep the optimized ones from the base image
RUN grep -vE "torch|torchvision" requirements.txt > requirements_no_torch.txt && \
    pip3 install --no-cache-dir -r requirements_no_torch.txt && \
    pip3 install --no-cache-dir .

# Pre-install plugins package
RUN iopaint install-plugins-packages

# Create a directory for models and outputs
RUN mkdir -p /root/.cache /app/outputs

EXPOSE 8080

# Default command to start IOPaint with LaMa on GPU
# We use --device cuda because ROCm's torch presents the GPU as 'cuda'
CMD ["iopaint", "start", "--model=lama", "--device=cuda", "--port=8080", "--host=0.0.0.0", "--input", "assets/dog.jpg"]
